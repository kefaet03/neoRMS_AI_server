# RMS AI Modules API Configuration
# Copy this file to .env and update values

# Application Settings
APP_NAME="RMS AI Modules API"
APP_VERSION="1.0.0"
DEBUG=false

# Server Settings
HOST=0.0.0.0
PORT=8888

# CORS Settings (comma-separated origins, use * for all)
CORS_ORIGINS=["*"]

# Gemini API Key (optional - for review analyzer)
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
